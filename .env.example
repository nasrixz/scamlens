# ==== Domain / public URLs ====
DOMAIN=scamlens.example.com
DNS_HOSTNAME=dns.scamlens.example.com
NEXT_PUBLIC_API_URL=https://scamlens.example.com/api
BLOCK_PAGE_IP=203.0.113.10      # public IP of this VPS (clients resolve to it)
LE_EMAIL=admin@scamlens.example.com  # contact for Let's Encrypt renewal notices

# ==== Postgres ====
POSTGRES_USER=scamlens
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=scamlens
DATABASE_URL=postgresql+asyncpg://scamlens:change_me_strong@postgres:5432/scamlens

# ==== Redis ====
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379/0

# ==== AI provider ====
AI_PROVIDER=anthropic           # anthropic | gemini | qwen
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Qwen via Alibaba DashScope (OpenAI-compatible endpoint).
# QWEN_API_KEY accepts the same value as DASHSCOPE_API_KEY.
QWEN_API_KEY=
QWEN_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ==== DNS upstream ====
UPSTREAM_DNS=1.1.1.1
UPSTREAM_DNS_FALLBACK=1.0.0.1
DOH_LISTEN_PORT=8053

# ==== Scanner tuning ====
SCAN_TIMEOUT_SECONDS=20
SAFE_TTL_SECONDS=86400          # 24h
SCAM_TTL_SECONDS=604800         # 7d
UNKNOWN_TTL_SECONDS=300         # 5m while scan pending

# ==== iOS profile signing (optional) ====
PROFILE_ORG=ScamLens
PROFILE_IDENTIFIER=com.scamlens.dns

# ==== App ====
LOG_LEVEL=INFO

# ==== Admin auth ====
# Secret for signing admin JWTs. Rotate invalidates all sessions.
# Generate: openssl rand -hex 48
JWT_SECRET=change_me_long_random_hex
JWT_TTL_HOURS=12

# ==== Social scraper (Threads keyword search) ====
# Long-lived user access token with scopes: threads_basic + threads_keyword_search
# Get from a Meta Developer app approved for keyword search.
THREADS_ACCESS_TOKEN=
THREADS_SEARCH_TYPE=RECENT
# Comma-separated keywords. Default has English + Malay scam terms; override
# in production to match your audience.
# THREADS_KEYWORDS=scam,fraud,phishing,penipuan,...
SCRAPE_DURATION_MINUTES=60
SCRAPE_INTERVAL_HOURS=24
SCRAPER_MAX_PAGES=10
SCRAPER_REQUEST_DELAY=2.0
SCRAPER_CONFIDENCE=70
